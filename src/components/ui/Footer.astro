---
const NavbarMenu: Array<{ name: string; url: string }> = [
	{ name: "หน้าแรก", url: "" },
	{ name: "เกี่ยวกับเรา", url: "" },
	{ name: "สินค้า", url: "" },
	{ name: "บทความ", url: "" },
	{ name: "ติดต่อเรา", url: "" },
	{ name: "สั่งซื้อ", url: "" },
];
---

<footer class="bg-primary">
  <div class="mx-auto w-full max-w-(--breakpoint-xl) p-4 py-6 lg:py-8">
    <div class="md:flex md:justify-between">
      <div class="mb-6 md:mb-0">
        <a href="/makusu-site" class="flex items-center">
          <img src="/makusu-site/logo.svg" class="h-8 me-3" alt="Makusu Logo" />
          <span
            class="self-center text-2xl font-semibold whitespace-nowra"
            >Makusu</span
          >
        </a>
      </div>
      <div class="grid grid-cols-2 gap-8 sm:gap-6 sm:grid-cols-3 p-2.5 rounded-2xl">
        <div>
          <h2
            class="mb-6 text-sm font-semibold uppercas"
          >
            เมนู
          </h2>
          <ul class="text-gray-500 font-medium">
            {
              NavbarMenu.map((item) => (
                <li class="mb-4">
                  <a href={item.url} class="hover:underline">
                    {item.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2
            class="mb-6 text-sm font-semibold uppercas"
          >
            ติดตามเรา
          </h2>
          <ul class="text-gray-500 font-medium">
            <li class="mb-4">
              <a
                href="https://www.facebook.com/MakusuPM"
                class="hover:underline">Facebook</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h2
            class="mb-6 text-sm font-semibold uppercas"
          >
            ข้อมูล
          </h2>
          <ul class="text-gray-500 font-medium">
            <li class="mb-4">
              <a href="#" class="hover:underline">Privacy Policy</a>
            </li>
            <li>
              <a href="#" class="hover:underline">Terms &amp; Conditions</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
    <hr class="my-6 border-gray-200 sm:mx-auto lg:my-8" />
    <div class="sm:flex sm:items-center sm:justify-between">
      <span class="text-sm text-gray-500 sm:text-center"
        >© 2024 <a href="/" class="hover:underline"
          >Makusu™</a
        >. All Rights Reserved.
      </span>
      <div class="flex mt-4 sm:justify-center sm:mt-0">
        <a
          href="#"
          class="text-gray-500 hover dark:hover:text-white"
        >
          <svg
            class="w-4 h-4"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="currentColor"
            viewBox="0 0 8 19"
          >
            <path
              fill-rule="evenodd"
              d="M6.135 3H8V0H6.135a4.147 4.147 0 0 0-4.142 4.142V6H0v3h2v9.938h3V9h2.021l.592-3H5V3.591A.6.6 0 0 1 5.592 3h.543Z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="sr-only">Facebook page</span>
        </a>
      </div>
    </div>
  </div>
</footer>
