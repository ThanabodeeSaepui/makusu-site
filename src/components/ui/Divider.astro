---
const List: { title: string; detail: string }[] = [
	{
		title: "Free Delivery",
		detail: "To Your Door",
	},
	{
		title: "Local Pickup",
		detail: "Check Out Locations",
	},
	{
		title: "Available for You",
		detail: "Online Support 24/7",
	},
	{
		title: "Order on the Line",
		detail: "click here",
	},
];
---

<div
  class="flex w-full flex-col lg:flex-row max-w-(--breakpoint-xl) mx-auto justify-center items-center gap-4 lg:gap-8"
>
  {
    List.map((item, index) => (
      <>
        <div class="card rounded-lg shadow-lg flex flex-col items-center justify-center h-32 max-w-md p-4 mx-2 transition-transform duration-300 hover:scale-105">
          <h3 class="text-white text-xl font-semibold mb-2">{item.title}</h3>
          <p class="text-white text-center text-sm">{item.detail}</p>
        </div>
        {index < List.length - 1 && (
          <div class="divider lg:divider-horizontal my-4 lg:my-0" />
        )}
      </>
    ))
  }
</div>
